# =============================================================================
# Object build statements for MODULE_LIBRARY target SimpleIndent


#############################################
# Order-only phony target for SimpleIndent

build cmake_object_order_depends_target_SimpleIndent: phony || cmake_object_order_depends_target_utils install/far2l.app/Contents/MacOS/far2l

build SimpleIndent/CMakeFiles/SimpleIndent.dir/src/SimpleIndent.cpp.o: CXX_COMPILER__SimpleIndent_unscanned_Release /Users/C5370280/SAPDevelop/far2l-adb/SimpleIndent/src/SimpleIndent.cpp || cmake_object_order_depends_target_SimpleIndent
